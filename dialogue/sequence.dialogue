import "res://dialogue/reset.dialogue" as reset
import "res://dialogue/snippets.dialogue" as snippets
import "res://dialogue/stimuli/orders.dialogue" as orders
# USAGE: Character.move_to(progress_ratio: float [0.0 - 1.0], duration: float [ >= 0.0 ])
# USAGE: Character.pivot(angle: float [-1.0 - 1.0], duration: float [ >= 0.0 ])
# USAGE: Character.tilt() Not yet used.
~ start
System: ...[next]
=>< reset/reset


~ ready
# User must "say" something for the prompt to be connected to them (allowed input from player)
System: .
- Start
	=>< reset/reset
	do overlay_state("hidden")
- Skip to spaceship_enter
	do overlay_state("hidden")
	=> approach_spaceship

- Skip to task1_stimuli_order
	do overlay_state("hidden")
	=> task1_stimuli_order

- Skip to task2_success
	do overlay_state("hidden")
	=> task2_success
[next=2]


~ intro_welcome
do Character.play_audio("intro_welcome")
Sam: Welcome to the Space Station! My name is Sam and I’m an Astronaut. We’re so glad you came to visit us today! Here at the space station, we go on so many fun missions. Come on in so I can show you around! [next=8]


~ intro_lucky
do Player.move_to(0.13,2.5)
do Player.pivot(-0.22,3)
do Character.move_to(0.15,2.5)
do Character.pivot(0.55,2.5)
[next=2]
do Character.play_audio("intro_lucky")
Sam: First, I want you to meet our very own space llama named Lucky. She’s usually around here somewhere... Let’s look her location up on our astronaut map. [next=5]

~ intro_map
do Character.move_to(0.27,3)
do Player.move_to(0.25,2.5)
[next=1.5]
do Character.pivot(0.0,1.5)
do Player.pivot(-0.35)
do Character.pivot(0,0.45)
[next=3]
do Character.play_audio("intro_map")
Sam: Oh no! It looks like Lucky’s spaceship broke down and Lucky is stuck on another planet way out in space! [next=3.5]
do Character.pivot(0.44,0.4)
[next=2]


~ question_rescue
do Character.play_audio("intro_question")
Sam: Will you help me rescue Lucky to get her back here to the space station?
- Yes. Continue.  


~ mission_brief
do Character.play_audio("intro_mission_brief")
Sam: Thank you! We’re definitely going to need your help -- this spaceship works best when I have a co-pilot astronaut like you! Our mission is to travel to Planet Stardust, where Lucky’s spaceship broke down, and bring Lucky the Llama back here safely. Are you ready to start your astronaut training? If you help, you’ll get your very own space cadet prize for your help and your bravery!!   [next=14]


~ approach_spaceship
do Player.move_to(0.65,6)
do Player.pivot(0,4)
[next=4]
do Player.pivot(-0.05,2)
do Player.tilt(0.35,2)
[next=1.5]

~ press_green_button
do Character.play_audio("intro_open_spaceship")
Sam: Press the GREEN button to open the spaceship door and start your training! [next=3]
set door_state = "ready"
Player: .
- Press Green Button

~ unlock_door
set door_state = "open"
[next=5]
do Player.pivot(0)
do Player.tilt(0,2)

~ spaceship_enter
do Player.move_to(0.85,2.5)
[next=0.25]
do Player.pivot(-0.4)
do Character.move_to(0.6,1.0)


~ spaceship_aboard
do Character.move_to(0.92,4.0)
[next=3]
do Character.pivot(0.6,2.0)
[next=1.5]
do Character.play_audio("welcome_aboard")
Sam: Welcome aboard! [next=1.5]

~ skip_to_launch
System: Debug Selection.
- Continue
- Skip to launch
	do overlay_state("hidden")
	=> launch

~ task0_practice
do Character.play_audio("task0_intro")
Sam: To become a Junior Astronaut, you will need to listen closely so we can make it to Planet Stardust, find Lucky the Llama, and bring Lucky back to the Space Station. [next=6]
do Character.pivot(0.5)
do Character.play_audio("task0_first_job")
Sam: Our first job is to make sure we have everything we need before we fly. [next=3]


~ task0_computer_intro
do Player.move_to(0.95,2)
do Player.pivot(-0.15)
do Character.move_to(0.97,2)
do Character.pivot(0.6)
[next=0.5]
set screen = "computer"
do Character.play_audio("task0_computer_info")
Sam: This is our handy dandy computer! The computer will help us travel to Planet Stardust. This is a super computer – which means it’s the only computer that contains a list of special phrases that we need to complete the mission! First, the computer will say the special phrases and then your job is to repeat the words out loud with your voice. [next=15]


~ computer_greeting  
do Character.play_audio("task0_computer_sounds_like")
Sam: This is what the computer sounds like. [next=1]
set screen = "talking"
do Stimuli.play("practice_0_greeting")
Computer: Nice to meet you [next=2]
set screen = "computer"
do Character.play_audio("task0_computer_instructions")
Sam: Ok, now I’ll have the computer say a special phrase and your job is to repeat what the computer just said with your voice when the light turns green. Make sure you say it loud and clear, so the computer can hear you! After you repeat after the computer, I’ll press the red button to tell the computer to send your voice to the spaceship. Ok here we go! [next=16]


~ activate_spaceship_recording
System: .
- Begin Recording
do Recorder.start()
set screen = "talking"
do Stimuli.play("practice_1_activate")
Computer: Activate spaceship! [next=2]
set screen = "recording"


~ activate_spaceship_result
System: ...
- Success
	set screen = "success"
	do Recorder.stop()
	do Recorder.save()
	do Character.play_audio("task0_ready_blast_off")
	Sam: Great job! Looks like it heard you! We’re ready to start preparing the ship for blast off. [next=4.5]
- Fail / Repeat
	set screen = "failure"
	do Recorder.stop()
	do Recorder.save("FAILURE")
	do Character.play_audio("listen_and_repeat")
	Sam: Listen to the command from the computer and then repeat what it says with your voice.  [next=3]
	# TODO: Recording not yet made.
	# do Character.play_audio("uh_oh")
	=> activate_spaceship_recording


~ spaceship_activated
set screen = "idle"
do Character.play_audio("task0_you_command")
Sam: I’ll sit here next to you and let you give the computer the voice commands! [next=3]
do Player.move_to(1,2)
do Character.move_to(1,2)
=>< snippets/focus_conversation
do Character.play_audio("task0_ready_green_button")
Sam: When you're ready, press the GREEN button to get started. [next=3]
=>< snippets/focus_screen
=>< snippets/prompt_green_button

~ buckle_up
set screen = "buckle_warning"
do Character.play_audio("task0_buckle_up_intro")
Sam: OK. First, we need to buckle up! Listen to the command from the computer and then repeat what it says with your voice. [next=5]
=>< snippets/focus_conversation


~ buckle_up_recording
System: ...
- Begin Recording
set screen = "talking"
do Recorder.start()
do Stimuli.play("practice_2_seatbelts")
Computer: Seat belts buckled! [next=2]
set screen = "recording"
[next=2]


~ buckle_up_result
System: ...
- Success
	set screen = "success"
	set seatbelts_buckled = true
	do Recorder.stop()
	do Recorder.save()
	=>< snippets/focus_conversation
	do Character.play_audio("great_job_heard_you")
	Sam: Great job! Looks like it heard you! [next=1.5]
	
- Fail / Repeat
	set screen = "failure"
	do Recorder.stop()
	do Recorder.save("FAILURE")
	=>< snippets/focus_conversation
	do Character.play_audio("listen_and_repeat")
	Sam: Listen to the command from the computer and then repeat what it says with your voice.  [next=3]
	=>< snippets/focus_screen
	=> buckle_up_recording


~ siren
set screen = "alert"
do Character.play_audio("task0_test_warning_sirens")
Sam: Great, now let’s test out our warning sirens! [next=2]
=>< snippets/focus_screen
do Character.play_audio("listen_and_repeat")
Sam: Listen to the command from the computer and then repeat what it says with your voice. [next=3]


