~ fuel_up
do Character.play_audio("task0_fuel_up_intro")
Sam: Awesome! We are almost ready to blast off, but first we need some fuel. 
[next=2]
set screen = "battery"


~ fuel_up_command
do Character.play_audio("listen_and_repeat")
Sam: Listen to the command from the computer and then repeat what it says with your voice:  
[next=0.5]
set screen = "computer"
Computer: Let’s fuel up!


~ fuel_up_recording
System: ...
- Begin Recording
set screen = "recording"
do Recorder.start()
[next=2]


~ fuel_up_result
System: ...
- Success
	set screen = "success"
	do Recorder.stop()
	do Recorder.save("speech", "PRAC_fuel_up")
	do Character.play_audio("great_job_heard_you")
	Sam: Great job! Looks like it heard you!
	=>< snippets/fuel_up_animation
- Quiet
	set screen = "failure"
	do Recorder.stop()
	Sam: Uh oh! It looks like the spaceship couldn't quite hear you. Let's try again a bit louder.
