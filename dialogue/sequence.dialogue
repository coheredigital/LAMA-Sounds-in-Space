~ task3_tones
=>< orders/tones

~ task3_stimuli_trial
# loop through stimuli
while stimuli_set.size() > 0
	set screen = "computer"
	do Ufo.pivot(-0.1, 1)
	set next_stimuli = stimuli_set.pop_front()
	System:
	- Begin {{next_stimuli}}
	set screen = "talking"
	do Stimuli.play(next_stimuli)
	do Recorder.start()
	[next=2]
	=>< snippets/recording_prompt
	[next=2]
	System:
	- Success
		do Alien.pivot(0.62)
		[next=0.5]
		do Alien.action("wave")
		do set_trial_progress_step(10 - stimuli_set.size(), 10,2)
		=>< snippets/success
		do Ufo.pivot(-0.5, 2)
		[next=1]
		do Ufo.activate_beam()
		do Ufo.set_search_progress(10 - stimuli_set.size(), 10, 2)
		[next=1]
		do Alien.pivot(0.15)
		[next=1]
		do Ufo.deactivate_beam()
	- Failure
		=>< snippets/failure
#		add the stimuli back into the front of the set so it can be repeated
		do stimuli_set.push_front(next_stimuli)
	[next=1]

# 10 stimuli – 5 pure tones, 5 intervals? *
~ task3_success
do Character.play_audio("task3_success")
do Ufo.activate_beam()
Sam: You did a great job! The aliens said Lucky the Llama is over there – look, they’re bringing Lucky to us! Now the only thing left to do is take Lucky back to the Space Station. [next]

do Ufo.pivot(0,4)
do Lama.action("wiggle")
do Lama.move_to(1,14)
do Ufo.move_to(0.975,14)
[next=14]
do Lama.action("idle")
do Ufo.deactivate_beam()
do Ufo.move_to(0.9,4)

# blast off and fade to intro (station)
~ mission_success
do Character.play_audio("task3_go_home")
Sam: Press the Green button to blast off back home! [next=2]
=>< snippets/prompt_green_button
do set_overlay_state("loading")
[next=1]
do play_spaceship_audio("effects/engine_boost")

do Lama.toggle_rescued(true)

do Player.move_to(0.21,0)
do Player.pivot(-0.42,0)
do Player.tilt(0.45,0)

do Character.move_to(0.325,0)
do Character.pivot(0.54,0)
do Character.tilt(0.4,0)

set journey_progress = 0
[next=6]
do set_overlay_state("hidden")
[next=2]
do Character.play_audio("mission_success")
Sam: You made it back to the Space Station - great job today! Thanks for bringing Lucky the Llama back home from Planet Stardust safely. You are a great Astronaut! Come back any time! [next=8]
