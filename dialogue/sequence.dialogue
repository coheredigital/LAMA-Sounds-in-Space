
import "res://dialogue/snippets/snippets.dialogue" as snippets

# USAGE: Character.move_to(progress_ratio: float [0.0 - 1.0], duration: float [ >= 0.0 ])
# USAGE: Character.pivot(angle: float [-1.0 - 1.0], duration: float [ >= 0.0 ])
# USAGE: Character.tilt() Not yet used.


~ start
System: ...[next]


~ reset
# it seems the below reset will only run properly
# if at least one line of dialogue has been shown
System: ...[next]
# character
do Character.move_to(0)
do Character.pivot(0)
do Character.tilt(0.25)
# player
do Player.move_to(0)
do Player.pivot(0)
# spaceship
set steering_motion = 0.0
set flying_motion = 0.0
set fuel_level = 1
# stars
set stars_brightness = 0.0
do move_star(1,0.0,0.0)
do move_star(2,0.0,0.0)
do move_star(3,0.0,0.0)
do move_star(4,0.0,0.0)
do move_star(5,0.0,0.0)
# delay start so tweens can finish
System: ...[next]
System: ...[next]
System: ...[next]
System: ...[next]


~ ready
# User must "say" something for the prompt to be connected to them (allowd input from player)
Player: ...
- Start
[next=2]


~ intro_welcome
do Character.play_audio("intro_welcome")
Sam: Welcome to the Space Station! My name is Sam and I’m an Astronaut. We’re so glad you came to visit us today! Here at the space station, we go on so many fun missions. Come on in so I can show you around!


~ intro_lucky
do Player.move_to(0.13,2.5)
[next=2]
do Character.play_audio("intro_lucky")
Sam: First, I want you to meet our very own space llama named Lucky. She’s usually around here somewhere... Let’s look up her location on our astronaut map.
[next=2]


~ intro_map
do Character.move_to(0.17,3)
do Player.move_to(0.3,2)
[next=1]
do Player.pivot(-0.25,1)
do Character.pivot(0,0.4)
[next=3]
# TODO: set station_screen = (starmap)
# TODO: set station_screen = (starmap_locate)
do Character.play_audio("intro_map")
Sam: Oh no! It looks like Lucky’s spaceship broke down and Lucky is stuck on another planet way out in space!
do Character.pivot(0.5,0.4)
[next=2]


~ question_rescue
do Character.play_audio("intro_question")
Sam: Will you help me rescue Lucky to get her back here to the space station?
Player: ...
- Yes!  
	do Character.play_audio("thank_you")
	Sam: Thank you!


~ mission_brief
do Character.play_audio("intro_mission_brief")
Sam: We’re definitely going to need your help -- this spaceship works best when I have a co-pilot astronaut like you! Our mission is to travel to Planet Stardust, where Lucky’s spaceship broke down, and bring Lucky the Llama back here safely. Are you ready to start your astronaut training? If you help, you’ll get your very own space cadet prize for your help and your bravery!!   


~ approach_spaceship
do Player.pivot(0,3)
do Player.move_to(0.65,6)
[next=5.5]


~ press_green_button
do Character.play_audio("intro_open_spaceship")
Sam: Press the GREEN button to open the spaceship door and start your training! 
Player: ...
- Press Green Button


~ unlock_door
set door_open = true
[next=5]


~ spaceship_enter
do Player.move_to(0.85,2.5)
[next=0.25]
do Player.pivot(-0.4)
do Character.move_to(0.6,1.0)


~ spaceship_aboard
do Character.move_to(0.9,4.0)
[next=3.5]
do Character.pivot(0.6,2.0)
[next=1.5]
do Character.play_audio("welcome_aboard")
Sam: Welcome aboard!


~ task0_practice
do Character.play_audio("task0_intro")
Sam: To become a Junior Astronaut, you will need to listen closely so we can make it to Planet Stardust, find Lucky the Llama, and bring Lucky back to the Space Station.
do Character.pivot(0.5)
do Character.play_audio("task0_job")
Sam: Our first job is to make sure we have everything we need before we fly.


~ task0_computer_intro
do Player.move_to(0.93,2)
do Player.pivot(-0.05,2)
do Character.move_to(0.96,2)
do Character.pivot(0.4)
[next=0.5]
set screen = "computer"
do Character.play_audio("task0_computer_info")
Sam: This is our handy dandy computer! The computer will help us travel to Planet Stardust. This computer is voice-activated, which means that we have to say the commands out loud with our voices so the computer can help us activate the spaceship! First, the computer will say the right words for a command and then your job is to repeat the words out loud with your voice.  


~ computer_greeting  
do Character.play_audio("task0_computer_sounds_like")
Sam: This is what the computer sounds like. 
[next=1]
do Stimuli.play("song_01F")
Computer: Nice to meet you
[next=0.5]
do Character.play_audio("task0_computer_instructions")
Sam: Ok, now I’ll have the computer say a command and your job is to repeat what the computer just said with your voice. Make sure you say it loud and clear, so the computer can hear you! After you repeat after the computer, I’ll press the red button to send your voice to the spaceship.


~ activate_spaceship
do Character.play_audio("ok_here_we_go")
Sam: Ok here we go!


~ activate_spaceship_command
set screen = "computer"
Computer: Activate spaceship!


~ activate_spaceship_recording
System: ...
- Begin Recording
	do Recorder.start()
	set screen = "recording"
	[next=2]


~ activate_spaceship_result
System: ...
- Success
	set screen = "success"
	do Recorder.stop()
	do Recorder.save("speech", "PRAC_activate_spaceship")
	do Character.play_audio("great_job_ready_blast_off")
	Sam: Great job! Looks like it heard you! We’re ready to start preparing the ship for blast off.
- Quiet
	set screen = "failure"
	do Recorder.stop()
	Sam: Uh oh! It looks like the spaceship couldn't quite hear what you said. Let's try again a bit louder.
	=> activate_spaceship_command



~ spaceship_activated
set screen = "idle"
do Character.play_audio("task0_you_command")
Sam: I’ll sit here next to you and let you give the computer the voice commands!
do Character.move_to(1.0,1.0) 
do Character.pivot(0) 
do Player.move_to(1.0,1.0)
do Player.pivot(-0.15)
do Character.play_audio("task0_ready_green_button")
Sam: When you're ready, press the GREEN button to get started. 
set screen = "start_button"
Player: ...
- Green Button


~ buckle_up
set screen = "buckle_warning"
do Character.pivot(0.25) 
do Character.play_audio("task0_buckle_up_intro")
Sam: OK. First, we need to buckle up! Listen to the command from the computer and then repeat what it says with your voice.
do Character.pivot(0)
do Player.pivot(0)


~ buckle_up_command
set screen = "computer"
Computer: Seat belts buckled!


~ buckle_up_recording
System: ...
- Begin Recording
set screen = "recording"
do Recorder.start()
[next=2]


~ buckle_up_result
System: ...
- Success
	set screen = "success"
	set seatbelts_buckled = true
	do Recorder.stop()
	do Recorder.save("speech", "PRAC_buckle_up")
	do Character.play_audio("great_job_heard_you")
	Sam: Great job! Looks like it heard you!
- Quiet
	set screen = "failure"
	do Recorder.stop()
	Sam: Uh oh! It looks like the spaceship couldn't quite hear what you said. Let's try again a bit louder.
	=> buckle_up_command


~ siren
do Character.play_audio("task0_test_warning_sirens")
Sam: Great, now let’s test out our warning sirens! 
set screen = "alert"
do Character.play_audio("listen_and_repeat")
Sam: Listen to the command from the computer and then repeat what it says with your voice.


~ siren_command
set screen = "computer"
Computer: Siren noise (low to high to low to high to low)


~ siren_recording
System: ...
